# PostgreSQL Configuration (leave as is for SQLite, or configure for PostgreSQL)
# For SQLite: sqlite:///agristock.db
# For PostgreSQL: postgresql://username:password@localhost:5432/agristock_db
DATABASE_URL=sqlite:///agristock.db

# JWT Configuration
JWT_SECRET_KEY=agristock-secret-key-2024
JWT_ACCESS_TOKEN_EXPIRES=3600

# Flask Configuration
FLASK_ENV=development
DEBUG=True

# Email Configuration (optional, for future features)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Email Configuration (for future email verification)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
